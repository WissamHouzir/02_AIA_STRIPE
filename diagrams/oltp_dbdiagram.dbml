Project stripe_oltp_simple {
  database_type: "PostgreSQL"
  note: "Modele OLTP simplifie pour Stripe : transactions, clients, marchands, paiements, remboursements et fraude."
}

Table customers {
  customer_id int [pk, increment]
  email varchar [unique, not null]
  country_code varchar(2)
  created_at timestamp
}

Table merchants {
  merchant_id int [pk, increment]
  merchant_name varchar [not null]
  country_code varchar(2)
  category varchar
  created_at timestamp
}

Table payment_methods {
  payment_method_id int [pk, increment]
  customer_id int [not null, ref: > customers.customer_id]
  payment_method_type varchar // card, wallet, bank_transfer
  brand varchar // visa, mastercard, amex
  last4 char(4)
  created_at timestamp
}

Table transactions {
  transaction_id int [pk, increment]
  merchant_id int [not null, ref: > merchants.merchant_id]
  customer_id int [not null, ref: > customers.customer_id]
  payment_method_id int [ref: > payment_methods.payment_method_id]
  transaction_amount decimal(12,2) [not null]
  currency varchar(3) [not null]
  transaction_datetime timestamp [not null]
  ip_country_code varchar(2)
  ip_city varchar
  device_type varchar // mobile, desktop, tablet, api
  status varchar [not null] // successful, failed, refunded
  created_at timestamp
}

Table payments {
  payment_id int [pk, increment]
  transaction_id int [not null, ref: > transactions.transaction_id]
  payment_method_id int [not null, ref: > payment_methods.payment_method_id]
  payment_status varchar
  processed_at timestamp
}

Table refunds {
  refund_id int [pk, increment]
  transaction_id int [not null, ref: > transactions.transaction_id]
  refund_amount decimal(12,2)
  refund_reason varchar
  refund_status varchar
  created_at timestamp
}

Table chargebacks {
  chargeback_id int [pk, increment]
  transaction_id int [not null, ref: > transactions.transaction_id]
  chargeback_amount decimal(12,2)
  reason varchar
  status varchar
  created_at timestamp
}

Table subscriptions {
  subscription_id int [pk, increment]
  customer_id int [not null, ref: > customers.customer_id]
  merchant_id int [not null, ref: > merchants.merchant_id]
  subscription_status varchar
  start_date date
  end_date date
}

Table fraud_indicators {
  fraud_indicator_id int [pk, increment]
  transaction_id int [not null, ref: > transactions.transaction_id]
  anomaly_score decimal(5,4)
  risk_level varchar // low, medium, high, critical
  evaluated_at timestamp
}
